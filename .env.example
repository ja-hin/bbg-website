# Stripe Configuration (Optional - for seamless card payments)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# PayU Configuration (Required for non-seamless payments)
PAYU_MERCHANT_KEY=your_payu_merchant_key_here
PAYU_SALT=your_payu_salt_here
PAYU_BASE_URL=https://test.payu.in

# For Production, use:
# PAYU_BASE_URL=https://secure.payu.in

# Database Configuration (Already configured for SQL Server)
# SQL Server connection is configured in server/db.ts

# Development Configuration
NODE_ENV=development